# ============================================================
# Armado Quant — OpenClaw Agent Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# Run: php artisan db:seed (in trade_middleware/) to generate tokens.

# Anthropic API Key (shared across all 11 agents)
CLAUDE_API_KEY=sk-ant-xxxxx

# Laravel Middleware Connection
MIDDLEWARE_BASE_URL=http://host.docker.internal:8000

# ── Agent API Tokens (generated by: php artisan db:seed) ──
# Each agent has its own unique token from the AgentSeeder output.
COORDINATOR_API_KEY=token-from-seeder
QUANT_RESEARCHER_API_KEY=token-from-seeder
BACKTESTER_API_KEY=token-from-seeder
RISK_OFFICER_API_KEY=token-from-seeder
SIGNAL_ENGINEER_API_KEY=token-from-seeder
EXECUTION_ENGINEER_API_KEY=token-from-seeder
MARKET_ANALYST_API_KEY=token-from-seeder
ALGORITHM_DESIGNER_API_KEY=token-from-seeder
PORTFOLIO_MANAGER_API_KEY=token-from-seeder
DATA_QUALITY_MONITOR_API_KEY=token-from-seeder
ONCHAIN_SENTIMENT_API_KEY=token-from-seeder

# ── Agent Gateway Ports (optional, defaults shown) ──
COORDINATOR_PORT=18800
QUANT_RESEARCHER_PORT=18801
BACKTESTER_PORT=18802
RISK_OFFICER_PORT=18803
SIGNAL_ENGINEER_PORT=18804
EXECUTION_ENGINEER_PORT=18805
MARKET_ANALYST_PORT=18806
ALGORITHM_DESIGNER_PORT=18807
PORTFOLIO_MANAGER_PORT=18808
DATA_QUALITY_MONITOR_PORT=18809
ONCHAIN_SENTIMENT_PORT=18810
